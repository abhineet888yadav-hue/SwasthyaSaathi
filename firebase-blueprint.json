{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Personalized academic and motivation profile for a student",
      "type": "object",
      "properties": {
        "goal": { "type": "string", "description": "Student's current academic goal" },
        "motivation": { "type": "string", "description": "Preferred counseling style" },
        "studyPreference": { "type": "string", "description": "Preferred study method" }
      },
      "required": ["goal", "motivation", "studyPreference"]
    },
    "HealthMetric": {
      "title": "Health Metric Record",
      "description": "Daily snapshot of a student's health and academic focus",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "sleepHours": { "type": "number" },
        "sleepTime": { "type": "string" },
        "mood": { "type": "string" },
        "studyHours": { "type": "number" },
        "status": { "type": "string" },
        "burnoutRisk": { "type": "string" },
        "burnoutProgress": { "type": "number" }
      },
      "required": ["date", "sleepHours", "mood", "studyHours", "status", "burnoutRisk", "burnoutProgress"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user customization data"
    },
    "/users/{userId}/history/{recordId}": {
      "schema": "HealthMetric",
      "description": "Stores historical health and study metrics"
    }
  }
}
